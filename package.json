{
  "name": "whatsappblast",
  "version": "1.0.0",
  "description": "WhatsApp 群发工具：扫码登录 + Excel 名单 + 个性化变量 + 图片附件 + 防封随机延迟",
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "start": "node src/server.js",
    "start:electron": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "test": "node --test"
  },
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5",
    "whatsapp-web.js": "^1.34.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.whatsappblast.app",
    "productName": "WhatsApp群发工具",
    "files": [
      "src/**/*",
      "public/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/puppeteer/**/*",
      "node_modules/whatsapp-web.js/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  }
}
